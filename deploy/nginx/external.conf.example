# =============================================================================
# 外部 Nginx 反代示例（放在宿主机 /etc/nginx/sites-available/srs-live-center.conf）
# =============================================================================
#
# 适用场景：
#   docker compose up -d 启动后，app 绑定在 127.0.0.1:8000，srs 绑定在
#   127.0.0.1:8080 / 127.0.0.1:1985；宿主机的 Nginx 把它们反代到公网。
#
# 依赖：
#   * 已签发 TLS 证书（推荐 Let's Encrypt），路径按实际填写。
#   * Nginx >= 1.25（需要 http2 新语法与 map 支持）。
#
# 启用：
#   sudo cp deploy/nginx/external.conf.example /etc/nginx/sites-available/srs-live-center.conf
#   sudo ln -s ../sites-available/srs-live-center.conf /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx
# =============================================================================

map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

# --- HTTP → HTTPS 强跳 ---
server {
    listen      80;
    listen      [::]:80;
    server_name live.example.com;
    location / { return 301 https://$host$request_uri; }
}

server {
    listen      443 ssl;
    listen      [::]:443 ssl;
    http2       on;
    server_name live.example.com;

    ssl_certificate     /etc/letsencrypt/live/live.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/live.example.com/privkey.pem;

    # 上传/直播包体不限制（推流走 RTMP 端口，这里只是保险）
    client_max_body_size 0;

    # ---------------------------------------------------------------
    # 1) HTTP-FLV / HLS 由 SRS 直接吐出
    # ---------------------------------------------------------------
    location ~* \.(flv|m3u8|ts)$ {
        proxy_pass              http://127.0.0.1:8080;
        proxy_http_version      1.1;
        proxy_set_header        Host $host;
        proxy_set_header        Connection '';
        proxy_buffering         off;
        proxy_request_buffering off;
        proxy_cache             off;
        add_header              Access-Control-Allow-Origin  *;
        add_header              Cache-Control no-cache;
    }

    # ---------------------------------------------------------------
    # 2) WebRTC WHIP/WHEP 信令走 SRS HTTP API
    # ---------------------------------------------------------------
    location /rtc/ {
        proxy_pass       http://127.0.0.1:1985;
        proxy_http_version 1.1;
        proxy_set_header Host $host;

        add_header Access-Control-Allow-Origin  *;
        add_header Access-Control-Allow-Methods 'GET, POST, OPTIONS';
        add_header Access-Control-Allow-Headers 'Content-Type, Authorization';
        if ($request_method = OPTIONS) { return 204; }
    }

    # ---------------------------------------------------------------
    # 3) 聊天 WebSocket
    # ---------------------------------------------------------------
    location /api/chat/ws/ {
        proxy_pass         http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_set_header   Upgrade           $http_upgrade;
        proxy_set_header   Connection        $connection_upgrade;
        proxy_read_timeout 3600s;
    }

    # ---------------------------------------------------------------
    # 4) 其他：REST API + SPA + http_hooks（后者由 SRS 在 Docker 内部直接
    #    调用，不经过这里，所以对外可安全暴露 /api/hooks/*）
    # ---------------------------------------------------------------
    location / {
        proxy_pass         http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
    }
}
